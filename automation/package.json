{
  "name": "@stefanini/tco-automation",
  "version": "1.0.0",
  "description": "AURA — AI-powered BDD test automation for TuCreditoOnline (GitHub Pages + backend API)",
  "author": "Stefanini Applied AI",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "cucumber-js",
    "test:en": "cucumber-js src/features/en/**/*.feature",
    "test:es": "cucumber-js src/features/es/**/*.feature",
    "test:pt": "cucumber-js src/features/pt/**/*.feature",
    "test:tag": "cucumber-js --tags",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "test:ci": "cucumber-js --tags @ci",
    "test:dry": "cucumber-js --dry-run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist reports/output"
  },
  "dependencies": {
    "@cucumber/cucumber": "^11.1.0",
    "@playwright/test": "^1.50.0",
    "dotenv": "^17.3.1",
    "openai": "^4.77.0",
    "playwright": "^1.50.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
